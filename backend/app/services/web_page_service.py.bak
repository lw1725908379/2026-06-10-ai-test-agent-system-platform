"""
Web 页面服务

处理 Web 页面相关的业务逻辑
"""

from typing import Optional
from uuid import UUID

from sqlalchemy.ext.asyncio import AsyncSession

from app.models.web_page import WebPage
from app.repositories.web_page_repo import WebPageRepository
from app.repositories.project_repo import ProjectRepository
from app.utils.exceptions import NotFoundException


class WebPageService:
    """Web 页面服务类"""

    def __init__(self, session: AsyncSession):
        self.session = session
        self.web_page_repo = WebPageRepository(session)
        self.project_repo = ProjectRepository(session)

    async def _get_project_by_identifier(self, identifier: str):
        """获取项目，不存在则抛出异常"""
        project = await self.project_repo.get_by_identifier(identifier)
        if not project:
            raise NotFoundException(resource_type="项目", resource_id=identifier)
        return project

    # ==================== Web 页面管理 ====================

    async def create_web_page(
        self,
        project_identifier: str,
        display_name: str,
        url: str,
        folder_id: Optional[str] = None,
        page_title: Optional[str] = None,
        description: Optional[str] = None,
        page_type: str = "page",
        elements: Optional[list] = None,
        navigation: Optional[dict] = None,
        tags: Optional[list] = None,
        tag_group: Optional[str] = None,
    ) -> dict:
        """创建 Web 页面定义"""
        project = await self._get_project_by_identifier(project_identifier)

        web_page = await self.web_page_repo.create(
            project_id=project.id,
            display_name=display_name,
            url=url,
            folder_id=UUID(folder_id) if folder_id else None,
            page_title=page_title,
            description=description,
            page_type=page_type,
            elements=elements,
            navigation=navigation,
            tags=tags,
            tag_group=tag_group,
        )

        return {
            "id": str(web_page.id),
            "display_name": web_page.display_name,
            "url": web_page.url,
            "page_title": web_page.page_title,
            "description": web_page.description,
            "page_type": web_page.page_type,
            "tag_group": web_page.tag_group,
            "created_at": web_page.created_at.isoformat(),
        }

    async def get_web_page(
        self,
        page_id: str,
    ) -> dict:
        """获取页面详情"""
        web_page = await self.web_page_repo.get_by_id(UUID(page_id))

        if not web_page:
            raise NotFoundException(resource_type="Web 页面", resource_id=page_id)

        return {
            "id": str(web_page.id),
            "display_name": web_page.display_name,
            "url": web_page.url,
            "page_title": web_page.page_title,
            "description": web_page.description,
            "page_type": web_page.page_type,
            "elements": web_page.elements,
            "navigation": web_page.navigation,
            "tags": web_page.tags,
            "tag_group": web_page.tag_group,
            "folder_id": str(web_page.folder_id) if web_page.folder_id else None,
            "total_test_cases": web_page.total_test_cases,
            "total_test_runs": web_page.total_test_runs,
            "created_at": web_page.created_at.isoformat(),
            "updated_at": web_page.updated_at.isoformat() if web_page.updated_at else None,
        }

    async def list_web_pages(
        self,
        project_identifier: str,
        page: int = 1,
        page_size: int = 20,
        folder_id: Optional[str] = None,
        search: Optional[str] = None,
    ) -> dict:
        """获取 Web 页面列表"""
        project = await self._get_project_by_identifier(project_identifier)

        offset = (page - 1) * page_size
        folder_uuid = UUID(folder_id) if folder_id else None
        items, total = await self.web_page_repo.get_by_project(
            project.id,
            offset=offset,
            limit=page_size,
            folder_id=folder_uuid,
            search=search,
        )

        return {
            "items": [
                {
                    "id": str(item.id),
                    "display_name": item.display_name,
                    "url": item.url,
                    "page_title": item.page_title,
                    "description": item.description,
                    "page_type": item.page_type,
                    "tag_group": item.tag_group,
                    "folder_id": str(item.folder_id) if item.folder_id else None,
                    "total_test_cases": item.total_test_cases,
                    "total_test_runs": item.total_test_runs,
                    "last_run_status": item.last_run_status,
                    "created_at": item.created_at.isoformat(),
                }
                for item in items
            ],
            "total": total,
            "page": page,
            "page_size": page_size,
        }

    async def update_web_page(
        self,
        page_id: str,
        display_name: Optional[str] = None,
        url: Optional[str] = None,
        description: Optional[str] = None,
        elements: Optional[list] = None,
        navigation: Optional[dict] = None,
    ) -> dict:
        """更新页面定义"""
        web_page = await self.web_page_repo.get_by_id(UUID(page_id))

        if not web_page:
            raise NotFoundException(resource_type="Web 页面", resource_id=page_id)

        update_data = {}
        if display_name is not None:
            update_data["display_name"] = display_name
        if url is not None:
            update_data["url"] = url
        if description is not None:
            update_data["description"] = description
        if elements is not None:
            update_data["elements"] = elements
        if navigation is not None:
            update_data["navigation"] = navigation

        updated = await self.web_page_repo.update(web_page, **update_data)

        return {
            "id": str(updated.id),
            "display_name": updated.display_name,
            "url": updated.url,
            "description": updated.description,
            "updated_at": updated.updated_at.isoformat() if updated.updated_at else None,
        }

    async def delete_web_page(
        self,
        page_id: str,
    ) -> None:
        """删除页面定义"""
        web_page = await self.web_page_repo.get_by_id(UUID(page_id))

        if not web_page:
            raise NotFoundException(resource_type="Web 页面", resource_id=page_id)

        await self.web_page_repo.delete(web_page)
