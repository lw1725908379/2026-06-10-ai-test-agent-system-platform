"""
Web 页面仓储

处理 Web 页面相关的数据库操作
"""

from typing import Optional
from uuid import UUID

from sqlalchemy import func, select
from sqlalchemy.ext.asyncio import AsyncSession

from app.repositories.base import BaseRepository
from app.models.web_page import WebPage


class WebPageRepository(BaseRepository[WebPage]):
    """Web 页面仓储类"""

    def __init__(self, session: AsyncSession):
        super().__init__(WebPage, session)

    async def get_by_project(
        self,
        project_id: UUID,
        offset: int = 0,
        limit: int = 20,
        folder_id: Optional[UUID] = None,
        search: Optional[str] = None,
    ) -> tuple[list[WebPage], int]:
        """获取项目下的 Web 页面列表"""
        query = select(WebPage).where(WebPage.project_id == project_id)

        if folder_id:
            query = query.where(WebPage.folder_id == folder_id)

        if search:
            query = query.where(
                (WebPage.display_name.ilike(f"%{search}%")) |
                (WebPage.url.ilike(f"%{search}%")) |
                (WebPage.description.ilike(f"%{search}%"))
            )

        count_result = await self.session.execute(
            select(func.count()).select_from(query.subquery())
        )
        total = count_result.scalar_one()

        query = query.order_by(WebPage.sort_order.asc(), WebPage.created_at.desc())
        query = query.offset(offset).limit(limit)

        result = await self.session.execute(query)
        items = list(result.scalars().all())

        return items, total

    async def get_by_folder(
        self,
        folder_id: UUID,
        offset: int = 0,
        limit: int = 20,
    ) -> tuple[list[WebPage], int]:
        """获取文件夹下的 Web 页面列表"""
        query = select(WebPage).where(WebPage.folder_id == folder_id)

        count_result = await self.session.execute(
            select(func.count()).select_from(query.subquery())
        )
        total = count_result.scalar_one()

        query = query.order_by(WebPage.sort_order.asc(), WebPage.created_at.desc())
        query = query.offset(offset).limit(limit)

        result = await self.session.execute(query)
        items = list(result.scalars().all())

        return items, total
