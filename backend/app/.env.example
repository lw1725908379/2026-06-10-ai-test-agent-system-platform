# 测试管理系统环境变量配置示例
# 复制此文件为 .env 并修改配置

# 应用配置
APP_NAME=测试管理系统
APP_VERSION=1.0.0
APP_PORT=3001
DEBUG=true

# PostgreSQL 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_test_management

# MongoDB 数据库配置
MONGODB_HOST=121.40.159.60
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_DB=ai_test_management

# 速率限制配置
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW=60

# 分页配置
PAGINATION_DEFAULT_SIZE=30
PAGINATION_MAX_SIZE=300

# CORS 配置（逗号分隔的域名列表）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# API 前缀
API_PREFIX=/api/v2

# MinIO 对象存储配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=test-management
MINIO_SECURE=false
MINIO_REGION=

# 附件配置
ATTACHMENT_MAX_SIZE=52428800  # 50 MB
