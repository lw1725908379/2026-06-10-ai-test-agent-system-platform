"""
Web 页面模型

定义 Web 页面定义的表结构
"""

from sqlalchemy import ForeignKey, Integer, String, Text, Enum as SQLEnum
from sqlalchemy.dialects.postgresql import UUID, JSONB
from sqlalchemy.orm import Mapped, mapped_column, relationship

from app.models.base import Base, TimestampMixin, UUIDMixin


# Web 页面类型枚举
class WebPageType(str):
    """Web 页面类型"""
    PAGE = "page"           # 完整页面
    COMPONENT = "component"  # 页面组件
    FLOW = "flow"           # 用户流程


class WebPage(Base, UUIDMixin, TimestampMixin):
    """
    Web 页面定义表

    存储 Web 应用的页面、组件和流程定义
    """
    __tablename__ = "web_pages"
    __table_args__ = {"comment": "Web 页面定义表"}

    # 基本信息
    project_id: Mapped[UUID] = mapped_column(
        UUID(as_uuid=True),
        ForeignKey("projects.id", ondelete="CASCADE"),
        nullable=False,
        index=True,
        comment="所属项目 ID"
    )
    folder_id: Mapped[UUID | None] = mapped_column(
        UUID(as_uuid=True),
        ForeignKey("folders.id", ondelete="CASCADE"),
        nullable=True,
        index=True,
        comment="所属文件夹 ID (可选)"
    )

    # 页面标识
    display_name: Mapped[str] = mapped_column(
        String(500),
        nullable=False,
        comment="页面显示名称,如 Login Page, Dashboard"
    )
    url: Mapped[str] = mapped_column(
        String(2048),
        nullable=False,
        comment="页面 URL (可以是相对路径)"
    )
    page_title: Mapped[str | None] = mapped_column(
        String(500),
        nullable=True,
        comment="页面标题"
    )

    # 页面描述
    description: Mapped[str | None] = mapped_column(
        Text,
        nullable=True,
        comment="页面描述"
    )

    # 页面类型
    page_type: Mapped[str] = mapped_column(
        String(50),
        nullable=False,
        default=WebPageType.PAGE,
        comment="页面类型: page, component, flow"
    )

    # 页面元素定义 (JSONB)
    elements: Mapped[dict | None] = mapped_column(
        JSONB,
        nullable=True,
        comment="页面交互元素列表 [{selector, type, name, description}]"
    )

    # 导航信息 (JSONB)
    navigation: Mapped[dict | None] = mapped_column(
        JSONB,
        nullable=True,
        comment="导航选项 {from_page, to_page, trigger}"
    )

    # 安全信息 (JSONB)
    security: Mapped[dict | None] = mapped_column(
        JSONB,
        nullable=True,
        comment="安全信息 {auth_required, permissions, ssl}"
    )

    # 标签和分组
    tags: Mapped[dict | None] = mapped_column(
        JSONB,
        nullable=True,
        comment="标签列表"
    )
    tag_group: Mapped[str | None] = mapped_column(
        String(200),
        nullable=True,
        index=True,
        comment="标签分组 (用于组织相关页面)"
    )

    # 关联的测试 IDs (JSONB)
    web_test_ids: Mapped[dict | None] = mapped_column(
        JSONB,
        nullable=True,
        comment="关联的 Web 测试 ID 列表"
    )

    # 自定义配置 (JSONB)
    custom_config: Mapped[dict | None] = mapped_column(
        JSONB,
        nullable=True,
        comment="自定义配置"
    )

    # 统计信息
    total_test_cases: Mapped[int] = mapped_column(
        Integer,
        default=0,
        comment="关联的测试用例总数"
    )
    total_test_runs: Mapped[int] = mapped_column(
        Integer,
        default=0,
        comment="测试运行总数"
    )
    last_run_status: Mapped[str | None] = mapped_column(
        String(50),
        nullable=True,
        comment="最后一次运行状态"
    )

    # 排序
    sort_order: Mapped[int] = mapped_column(
        Integer,
        default=0,
        comment="排序顺序"
    )

    # 关系
    project: Mapped["Project"] = relationship(
        "Project"
    )
    folder: Mapped["Folder | None"] = relationship(
        "Folder"
    )
