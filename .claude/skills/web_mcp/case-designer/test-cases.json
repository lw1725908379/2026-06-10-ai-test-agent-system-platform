[
  {
    "name": "标准用户成功登录",
    "description": "验证使用 standard_user 和有效密码 secret_sauce 可以成功登录到 inventory 页面",
    "priority": "high",
    "prerequisites": [
      "用户未登录",
      "saucedemo.com 可访问"
    ],
    "steps": [
      {
        "step_number": 1,
        "action": "navigate",
        "description": "导航到登录页面",
        "target": "登录页面",
        "locator": null,
        "data": "https://www.saucedemo.com"
      },
      {
        "step_number": 2,
        "action": "fill",
        "description": "填写用户名",
        "target": "用户名输入框",
        "locator": "locator('[data-test=\"username\"]')",
        "data": "standard_user"
      },
      {
        "step_number": 3,
        "action": "fill",
        "description": "填写密码",
        "target": "密码输入框",
        "locator": "locator('[data-test=\"password\"]')",
        "data": "secret_sauce"
      },
      {
        "step_number": 4,
        "action": "click",
        "description": "点击登录按钮",
        "target": "登录按钮",
        "locator": "locator('[data-test=\"login-button\"]')",
        "data": null
      }
    ],
    "expected_result": "用户成功登录并跳转到 inventory 页面，显示 Products 标题和商品列表",
    "verification_points": [
      {
        "type": "url",
        "description": "验证 URL 已跳转到 inventory 页面",
        "locator": null,
        "expected": "/inventory.html"
      },
      {
        "type": "element_visible",
        "description": "验证 Products 标题可见",
        "locator": "getByText('Products')",
        "expected": true
      }
    ],
    "page_elements": [
      {
        "name": "用户名输入框",
        "locator": "locator('[data-test=\"username\"]')",
        "type": "textbox"
      },
      {
        "name": "密码输入框",
        "locator": "locator('[data-test=\"password\"]')",
        "type": "textbox"
      },
      {
        "name": "登录按钮",
        "locator": "locator('[data-test=\"login-button\"]')",
        "type": "button"
      }
    ],
    "tags": ["authentication", "login", "smoke-test", "critical"]
  },
