{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "_buildId": "id_MC81OmFIVnBZMlhsaUpqbWxvYzZWMFJNTkE9PTo3ZTI0YjQwZg==",
  "title": "Penetration Testing Report",
  "_deployId": "id_MS81OmFIVnBZMlhsaUpqbWxvYzZWMFJNTkE9PTo3ZTI0YjQwZg==",
  "description": "JSON schema for penetration testing report generated by pentest-skills results-storage",
  "_releaseId": "id_Mi81OmFIVnBZMlhsaUpqbWxvYzZWMFJNTkE9PTo3ZTI0YjQwZg==",
  "type": "object",
  "_versionId": "id_My81OmFIVnBZMlhsaUpqbWxvYzZWMFJNTkE9PTo3ZTI0YjQwZg==",
  "required": [
    "metadata",
    "executive_summary",
    "statistics",
    "hosts",
    "vulnerabilities"
  ],
  "_buildHash": "NC81OmFIVnBZMlhsaUpqbWxvYzZWMFJNTkE9PTo3ZTI0YjQwZg==",
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Report metadata",
      "required": [
        "report_date",
        "test_period",
        "testers"
      ],
      "properties": {
        "report_date": {
          "type": "string",
          "format": "date",
          "description": "Report generation date (YYYY-MM-DD)"
        },
        "test_period": {
          "type": "object",
          "properties": {
            "start": {
              "type": "string",
              "format": "date"
            },
            "end": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "testers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "subsystem": {
          "type": "string",
          "description": "Subsystem name if report is subsystem-specific"
        }
      }
    },
    "executive_summary": {
      "type": "object",
      "required": [
        "risk_score",
        "risk_level",
        "total_vulnerabilities",
        "total_hosts",
        "severity_breakdown"
      ],
      "properties": {
        "risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Overall risk score (0-10)"
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "None",
            "Minimal",
            "Low",
            "Medium",
            "High",
            "Critical"
          ]
        },
        "total_vulnerabilities": {
          "type": "integer"
        },
        "total_hosts": {
          "type": "integer"
        },
        "severity_breakdown": {
          "type": "object",
          "properties": {
            "Critical": {
              "type": "integer"
            },
            "High": {
              "type": "integer"
            },
            "Medium": {
              "type": "integer"
            },
            "Low": {
              "type": "integer"
            },
            "Info": {
              "type": "integer"
            }
          }
        }
      }
    },
    "statistics": {
      "type": "object",
      "description": "Detailed statistics",
      "properties": {
        "subsystem": {
          "type": "string"
        },
        "total_hosts": {
          "type": "integer"
        },
        "total_vulnerabilities": {
          "type": "integer"
        },
        "severity_breakdown": {
          "type": "object"
        },
        "type_breakdown": {
          "type": "object"
        },
        "average_cvss": {
          "type": "number"
        }
      }
    },
    "hosts": {
      "type": "array",
      "description": "List of all discovered hosts",
      "items": {
        "type": "object",
        "properties": {
          "ip_address": {
            "type": "string"
          },
          "hostname": {
            "type": "string"
          },
          "os_fingerprint": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "subsystem_name": {
            "type": "string"
          },
          "port_count": {
            "type": "integer"
          },
          "vuln_count": {
            "type": "integer"
          }
        }
      }
    },
    "vulnerabilities": {
      "type": "object",
      "description": "Vulnerabilities grouped by severity",
      "properties": {
        "Critical": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/vulnerability"
          }
        },
        "High": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/vulnerability"
          }
        },
        "Medium": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/vulnerability"
          }
        },
        "Low": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/vulnerability"
          }
        },
        "Info": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/vulnerability"
          }
        }
      }
    }
  },
  "definitions": {
    "vulnerability": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "vulnerability_type": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "Critical",
            "High",
            "Medium",
            "Low",
            "Info"
          ]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "affected_component": {
          "type": "string"
        },
        "proof_of_concept": {
          "type": "string"
        },
        "cvss_score": {
          "type": "number"
        },
        "cwe_id": {
          "type": "string"
        },
        "cve_id": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "discovered_at": {
          "type": "string",
          "format": "date-time"
        },
        "discovered_by_skill": {
          "type": "string"
        },
        "host_ip": {
          "type": "string"
        },
        "hostname": {
          "type": "string"
        },
        "os_fingerprint": {
          "type": "string"
        },
        "subsystem_name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "parameter": {
          "type": "string"
        },
        "http_method": {
          "type": "string"
        },
        "payload": {
          "type": "string"
        },
        "response_evidence": {
          "type": "string"
        },
        "context": {
          "type": "string"
        }
      }
    }
  }
}