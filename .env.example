# ============================================================
# 智能测试平台 - 环境变量配置模板
# ============================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# ============================================================

# ============================================================
# 1. 应用基础配置
# ============================================================
APP_NAME=智能测试平台
APP_VERSION=2.0.0
APP_PORT=3001
DEBUG=true
API_PREFIX=/api/v2

# ============================================================
# 2. 大语言模型 (LLM) 配置
# ============================================================
DEEPSEEK_API_KEY=your-deepseek-api-key
LLM_MODEL=deepseek-chat

# 图片解析模型（可选）
IMAGE_PARSER_API_KEY=your-image-parser-api-key
IMAGE_PARSER_API_BASE=https://ark.cn-beijing.volces.com/api/v3
IMAGE_PARSER_MODEL=doubao-seed-2-0-mini-260428

# ============================================================
# 3. LangSmith 监控（可选）
# ============================================================
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ============================================================
# 4. 数据库配置
# ============================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=ai_test_platform_db

MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=ai_test_platform

REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================
# 5. MinIO 对象存储
# ============================================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=test-management
MINIO_SECURE=false

# ============================================================
# 6. 安全配置
# ============================================================
SECRET_KEY=change-this-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_DEV_SECRET=change-this-to-another-secret-key

# ============================================================
# 7. API 路由
# ============================================================
BACKEND_API_URL=http://backend:3001
API_PREFIX=/api/v2
LANGGRAPH_API_URL=http://localhost:2026

# ============================================================
# 8. Agent Workspace 路径（Docker 内使用相对路径）
# ============================================================
TESTCASE_WORKSPACE_ROOT=backend/workspace/testcase
TESTCASE_SKILLS_ROOT=.claude/skills

API_WORKSPACE_ROOT=backend/workspace/api
API_SKILLS_ROOT=.claude/skills

WEB_MCP_WORKSPACE_ROOT=backend/workspace/web_mcp
WEB_MCP_ROOT=backend/workspace/web_mcp
WEB_MCP_SKILLS_ROOT=.claude/skills

WEB_CLI_WORKSPACE_ROOT=backend/workspace/web_cli
WEB_CLI_SKILLS_ROOT=.claude/skills

WEB_CHROME_WORKSPACE_ROOT=backend/workspace/web_chrome
WEB_CHROME_MCP_ROOT=backend/mcp/web_chrome
WEB_CHROME_SKILLS_ROOT=backend/workspace/web_chrome

PERF_WORKSPACE_ROOT=backend/workspace/perf
PERF_MCP_ROOT=backend/mcp/perf
PERF_SKILLS_ROOT=.claude/skills/performance

SECURITY_WORKSPACE_ROOT=backend/workspace/security
SECURITY_SKILLS_ROOT=.claude/skills

ANDROID_WORKSPACE_ROOT=backend/workspace/android
ANDROID_SKILLS_ROOT=.claude/skills

# ============================================================
# 9. RAG 服务
# ============================================================
RAG_API_URL=http://rag-api:9623
RAG_MCP_URL=http://rag-mcp:8003
RAG_USERNAME=admin
RAG_PASSWORD=admin123
RAG_WORKSPACE_ROOT=rag/storage
RAG_INPUT_ROOT=rag/inputs

# ============================================================
# 10. Embedding 服务
# ============================================================
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://llm-xxx.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
